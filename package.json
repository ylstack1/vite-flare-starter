{
  "name": "vite-flare-starter",
  "version": "1.9.0",
  "private": true,
  "type": "module",
  "description": "Production-ready AI agent starter kit for Cloudflare Workers — 53+ tools, skills, conversation persistence, multi-provider AI, and full AI SDK v6 patterns",
  "author": "Jeremy Dawes (Jezweb)",
  "license": "MIT",
  "scripts": {
    "dev": "vite dev",
    "build": "tsc && vite build",
    "preview": "wrangler dev",
    "deploy": "pnpm build && wrangler deploy",
    "cf:login": "wrangler login",
    "db:generate": "drizzle-kit generate",
    "db:generate:named": "drizzle-kit generate --name",
    "db:migrate:local": "wrangler d1 migrations apply vite-flare-starter-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply vite-flare-starter-db --remote",
    "db:migrate:list:local": "wrangler d1 migrations list vite-flare-starter-db --local",
    "db:migrate:list:remote": "wrangler d1 migrations list vite-flare-starter-db --remote",
    "db:studio:local": "drizzle-kit studio",
    "db:seed": "npx tsx scripts/seed.ts",
    "models:refresh": "npx tsx scripts/refresh-models.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:agent": "bash scripts/test-agent.sh",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "type-check": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "tool-coverage": "node scripts/tool-coverage.mjs",
    "doctor:auth": "node scripts/doctor-auth.mjs",
    "doctor:models": "node scripts/doctor-models.mjs"
  },
